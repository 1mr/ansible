/var/log/nginx/*.log {
        daily
        missingok
        rotate 14
        compress
        compresscmd /usr/bin/pigz
        delaycompress
        notifempty
        create 644 www-data adm
        sharedscripts
        postrotate
                [ -f /var/run/nginx.pid ] && kill -USR1 `cat /var/run/nginx.pid`
        endscript
}
