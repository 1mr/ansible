{{ ansible_managed | comment }}
server {
    listen {% if item.listen is defined %}{{ item.listen }}:{% endif %}{% if item.http_port is defined %}{{ item.http_port }}{% else %}80{% endif %};
{% if item.ipv6 is defined %}
    listen {% if item.listen is defined %}{{ item.listen }}:{% if item.http_port is defined %}{{ item.http_port }}{% else %}80{% endif %}{% else %}[::]:{% if item.http_port is defined %}{{ item.http_port }}{% else %}80{% endif %}{% endif %};
{% endif %}
    server_name {{ item.name }}{% if item.aliases is defined %} {{ item.aliases }}{% endif %};
{% if item.ssl is defined or item.letsencrypt is defined %}
{% include 'templates/acme_challenge.j2' %}
    return 301 https://$server_name$request_uri;
}

server {
    listen {% if item.listen is defined %}{{ item.listen }}:{% endif %}{% if item.https_port is defined %}{{ item.https_port }}{% else %}443{% endif %} ssl;
{% if item.ipv6 is defined %}
    listen {% if item.listen is defined %}{{ item.listen }}:{% if item.https_port is defined %}{{ item.https_port }}{% else %}443{% endif %} ssl{% else %}[::]:{% if item.https_port is defined %}{{ item.https_port }}{% else %}443{% endif %} ssl{% endif %};
{% endif %}
    http2 on;
{% include 'templates/ssl.j2' %}

    server_name {{ item.name }}{% if item.aliases is defined %} {{ item.aliases }}{% endif %};
{% endif %}

{% include 'templates/log.j2' %}

{% if item.custom_root is defined %}
    root {{ item.custom_root }};
{% else %}
    root /usr/sites/{{ item.root|default(item.name) }};
{% endif %}

    index index.html;

    location = /favicon.ico { log_not_found off; access_log off; }
    location = /apple-touch-icon.png { log_not_found off; access_log off; }
    location = /apple-touch-icon-precomposed.png { log_not_found off; access_log off; }
    location = /robots.txt { log_not_found off; access_log off; }
    location ~* (readme.html|license.txt|readme.txt) { return 404; }
    location ~ ^/(README|INSTALL|LICENSE|CHANGELOG|UPGRADING|bin|SQL)$ { return 404; }
    location ~ /\.(?!well-known) { return 404; }

    location / {
        sendfile   on;
        tcp_nopush on;
{% if item.try_files is defined %}
        try_files {{ item.try_files }};
{% else %}
        try_files $uri $uri/ =404;
{% endif %}
    }
}
