<?xml version="1.0"?>
<!--
  Cluster Configuration. Generated by Ansible.
-->
<clickhouse>
    <!-- Remote servers (cluster configuration) -->
    <remote_servers>
{% for cluster_name in clickhouse_clusters.keys() | sort %}
        <{{ cluster_name }}>
{% for shard_id in clickhouse_clusters[cluster_name].servers | sort %}
            <shard>
                <internal_replication>true</internal_replication>
{% for replica in clickhouse_clusters[cluster_name].servers[shard_id] | sort(attribute='replica_id') %}
                <replica>
                    <host>{{ replica.host }}</host>
                    <port>{{ clickhouse_tcp_port }}</port>
{% if replica.default_database is defined %}
                    <default_database>{{ replica.default_database }}</default_database>
{% endif %}
                </replica>
{% endfor %}
            </shard>
{% endfor %}
        </{{ cluster_name }}>
{% endfor %}
    </remote_servers>

    <!-- Macros for distributed DDL -->
    <macros>
{% if clickhouse_clusters | length > 0 %}
{%   set first_cluster_name = clickhouse_clusters.keys() | list | first %}
{%   set first_cluster_config = clickhouse_clusters[first_cluster_name] %}
{%   set ns = namespace(shard_name='', replica_id=1) %}
{%   for shard_name in first_cluster_config.servers | sort %}
{%     for replica in first_cluster_config.servers[shard_name] %}
{%       if replica.host == inventory_hostname %}
{%         set ns.shard_name = first_cluster_config.get('shard', 1)  %}
{%         set ns.replica_id = replica.replica_id %}
{%       endif %}
{%     endfor %}
{%   endfor %}
        <cluster>{{ first_cluster_name }}</cluster>
        <shard>{{ ns.shard_name }}</shard>
        <replica>{{ ns.replica_id }}</replica>
{% endif %}
    </macros>

    <!-- Distributed DDL -->
    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
    </distributed_ddl>
</clickhouse>
