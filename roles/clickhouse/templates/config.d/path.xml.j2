<?xml version="1.0"?>
<!--
  Path Configuration. Generated by Ansible.
-->
<clickhouse>
    <!-- Path to the directory containing data -->
    <path>{{ clickhouse_path_data }}/</path>

    <!-- Path on the local filesystem to store temporary data for processing large queries -->
    <tmp_path>{{ clickhouse_path_tmp }}/</tmp_path>

    <!-- The directory with user files. Used in the table function file(), fileCluster() -->
    <user_files_path>{{ clickhouse_path_user_files }}/</user_files_path>

    <!-- Sources to read users, roles, access rights, profiles of settings, quotas -->
    <user_directories>
        <users_xml>
            <!-- Path to configuration file with predefined users -->
            <path>{{ clickhouse_users_xml_path | default('users.xml') }}</path>
        </users_xml>
{% if clickhouse_cluster_enabled %}
        <replicated>
            <zookeeper_path>/clickhouse/access/</zookeeper_path>
        </replicated>
{% else %}
        <local_directory>
            <!-- Path to folder where users created by SQL commands are stored -->
            <path>{{ clickhouse_path_access | default(clickhouse_path_base ~ '/access') }}/</path>
        </local_directory>
{% endif %}
    </user_directories>

    <!-- The directory containing the top level domains list -->
    <top_level_domains_path>{{ clickhouse_path_top_level_domains | default(clickhouse_path_base ~ '/top_level_domains') }}/</top_level_domains_path>

    <!-- Directory containing schema files for various input formats -->
    <format_schema_path>{{ clickhouse_path_format_schema }}/</format_schema_path>
</clickhouse>
