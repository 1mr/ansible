<?xml version="1.0"?>
<!--
  ClickHouse Keeper Client Configuration. Generated by Ansible.
  This configures ClickHouse Server to connect to ClickHouse Keeper ensemble
-->
<clickhouse>
    <!-- ClickHouse Keeper (ZooKeeper replacement) -->
    <zookeeper>
{% for h,v in clickhouse_keeper_servers.items()  %}
        <node>
            <host>{{ v.hostname }}</host>
            <port>{{ clickhouse_keeper_port }}</port>
        </node>
{% endfor %}
    </zookeeper>
</clickhouse>
