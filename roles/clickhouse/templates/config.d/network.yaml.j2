# Network Configuration. Generated by Ansible.

clickhouse:
  listen_host:
    - {{ clickhouse_listen_host }}
{% if clickhouse_listen_host != '0.0.0.0' and clickhouse_listen_host != '127.0.0.1' %}
    - 127.0.0.1
{% endif %}

{% if clickhouse_cluster_enabled | default(false) %}
  # Interserver HTTP host for replication (advertised to other nodes)
  interserver_http_host: {{ clickhouse_advertise_host }}
{% endif %}
