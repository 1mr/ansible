<?xml version="1.0"?>
<!-- Default Profiles Configuration. Generated by Ansible. -->
<clickhouse>
<!-- Settings profiles -->
  <profiles>
{% for k,v in clickhouse_profiles.items()  %}
    <{{ k }}>
      {%- for k,v in v.items()  -%}
      <{{ k }}>{{ v }}</{{ k }}>
      {%- endfor -%}
    </{{ k }}>
{% endfor %}
  </profiles>
</clickhouse>
