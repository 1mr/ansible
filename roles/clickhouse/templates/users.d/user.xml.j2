<?xml version="1.0"?>
<!-- Default User Configuration. Generated by Ansible. -->
<clickhouse>
    <users>
{% for k,v in clickhouse_users.items()  %}
        <{{ k }}>
            <password_sha256_hex>{{ v.password_sha256_hex }}</password_sha256_hex>
{% if v.network is defined %}
            <networks>
{% for network in v.network %}
                <ip>{{ network }}</ip>
{% endfor %}
            </networks>
{% endif %}
{% if v.access_management is defined %}
            <access_management>{{ v.access_management }}</access_management>
{% endif %}
{% if v.named_collection_control is defined %}
            <named_collection_control>{{ v.named_collection_control }}</named_collection_control>
{% endif %}
{% if v.show_named_collections_secrets is defined %}
            <show_named_collections_secrets>{{ v.show_named_collections_secrets }}</show_named_collections_secrets>
{% endif %}
{% if v.profile is defined %}
            <profile>{{ v.profile }}</profile>
{% endif %}
{% if v.quota is defined %}
            <quota>{{ v.quota }}</quota>
{% endif %}
        </{{ k }}>
{% endfor %}
    </users>
</clickhouse>
