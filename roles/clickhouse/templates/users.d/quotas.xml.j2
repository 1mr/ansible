<?xml version="1.0"?>
<!-- Default Quotas Configuration. Generated by Ansible. -->
<clickhouse>
<!-- Settings quotas -->
  <quotas>
{% for k,v in clickhouse_quotas.items()  %}
    <{{ k }}>
      {%- if v.interval is defined -%}
      <interval>
        {%- for k,v in v.interval.items()  -%}
          <{{ k }}>{{ v }}</{{ k }}>
        {%- endfor -%}
      </interval>
      {%- endif -%}
    </{{ k }}>
{% endfor %}
  </quotas>
</clickhouse>
