#!/bin/bash
set -o pipefail

backup_parent_dir="/data/backups/mysql"
backup_date=`date +%Y-%m-%d`
backup_dir="${backup_parent_dir}/${backup_date}"
echo "Backup directory: ${backup_dir}"
mkdir -p "${backup_dir}"
chmod 755 "${backup_dir}"
HOSTNAME=`hostname -f`

# report backup status to victoriametrics
VMAGENT_URL="http://127.0.0.1:8429"
METRIC_LABELS="job=\"backup\",type=\"mysql\",instance=\"${HOSTNAME}\""
backup_start_time=`date +%s`
backup_success=1   # 1 = success, 0 = failure

push_metrics() {
  [ "$?" -ne 0 ] && backup_success=0
  backup_end_time=`date +%s`
  backup_duration=$((backup_end_time - backup_start_time))

  metrics="backup_success{${METRIC_LABELS}} ${backup_success}
backup_duration_seconds{${METRIC_LABELS}} ${backup_duration}"
  if [ "${backup_success}" -eq 1 ]; then
    metrics="${metrics}
backup_last_success_seconds{${METRIC_LABELS}} ${backup_end_time}"
  fi

  if curl -sf -o /dev/null --max-time 5 "${VMAGENT_URL}/health"; then
    printf '%s\n' "${metrics}" | curl -s --max-time 10 --data-binary @- "${VMAGENT_URL}/api/v1/import/prometheus"
  else
    logger "vmagent not reachable at ${VMAGENT_URL}, skipping backup metrics"
  fi
}
trap push_metrics EXIT

MYSQL_CLI=`which mariadb || which mysql`
MYSQLDUMP_CLI=`which mariadb-dump || which mysqldump`

# set DAYS
if [ -n "$1" ]; then
  DAYS=$1
else
  DAYS={{ item.retention | default("14") }}
fi

logger "*** Start MySQL Backup ***"

mysql_databases=`echo 'show databases' | $MYSQL_CLI -B | sed /^Database$/d`

# Backup and compress each database
for database in $mysql_databases
do
  if [ "${database}" == "information_schema" ] || [ "${database}" == "performance_schema" ] || [ "${database}" == "sys" ] ; then
        echo "Skipping backup of \"${database}\" database"
  else
    if [ "${database}" == "mysql" ] ; then
        additional_mysqldump_params="--events --ignore-table=mysql.event"
        echo "Creating backup of \"${database}\" database"
        bkp_date=`date '+%F_%H-%M'`
        $MYSQLDUMP_CLI ${additional_mysqldump_params} ${database} | pigz > "${backup_dir}/${HOSTNAME}_${database}_${bkp_date}.tgz" || backup_success=0
        chmod 600 "${backup_dir}/${HOSTNAME}_${database}_${bkp_date}.tgz"
    else
        additional_mysqldump_params="--max_allowed_packet=512M --single-transaction"
        echo "Creating backup of \"${database}\" database"
        bkp_date=`date '+%F_%H-%M'`
        $MYSQLDUMP_CLI ${additional_mysqldump_params} ${database} | pigz > "${backup_dir}/${HOSTNAME}_${database}_${bkp_date}.tgz" || backup_success=0
        chmod 600 "${backup_dir}/${HOSTNAME}_${database}_${bkp_date}.tgz"
    fi
  fi
done

logger "*** Delete MySQL backups older than ${DAYS} days ***"

# Delete backups older than ${days}
find ${backup_parent_dir} -name '*' -type d -mtime +${DAYS} -prune -exec rm -rfv "{}" \;

logger "*** Finish MySQL Backup ***"
